# Server
PORT=4000
NODE_ENV=development

# SQLite (file path, relative to backend/)
DB_FILE=./db/recon.sqlite

# Reconciliation tuning
AMOUNT_TOLERANCE=0.01
DATE_WINDOW_DAYS=1

# Background worker
# Set WORKER_ENABLED=false to run the API without the in-process worker
# (e.g. when running a dedicated worker process).
WORKER_ENABLED=true
WORKER_POLL_MS=500
RECONCILE_MAX_ATTEMPTS=3
